{
  "name": "akita-neru",
  "version": "1.0.0",
  "description": "Secure and extensible open-source Discord moderation bot",
  "private": true,
  "files": [
    ".env.example",
    "commands/",
    "events/",
    "lib/",
    "scripts/",
    "index.js",
    "run.bat",
    "run.sh",
    "SECURITY.md"
  ],
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "deploy:commands": "node scripts/deploy-commands.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude=test/** --test-coverage-lines=90 --test-coverage-branches=80 --test-coverage-functions=85",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "npm audit --audit-level=moderate",
    "check": "npm run lint && npm run format:check && npm run test:coverage"
  },
  "engines": {
    "node": "^22.13.0 || ^24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meiruoyeta/Akita-Neru.git"
  },
  "keywords": [
    "moderation",
    "discord"
  ],
  "author": "meiruoyeta",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/meiruoyeta/Akita-Neru/issues"
  },
  "homepage": "https://github.com/meiruoyeta/Akita-Neru#readme",
  "dependencies": {
    "discord.js": "14.26.5",
    "dotenv": "^17.4.2"
  },
  "overrides": {
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.3.0",
    "prettier": "^3.9.5"
  }
}
